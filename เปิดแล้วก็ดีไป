local function IsZoneOccupied(zoneCFrame)
    local zonePos = zoneCFrame.Position

    for _, obj in ipairs(workspace:GetChildren()) do
        if obj.Name == "MatchZoneBlocker" then

            local pos
            if obj:IsA("BasePart") then
                pos = obj.Position
            elseif obj:IsA("Model") and obj.PrimaryPart then
                pos = obj.PrimaryPart.Position
            end

            if pos and (pos - zonePos).Magnitude < 5 then
                return true
            end
        end
    end

    return false
end


local function Teleport(cframe)
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")

    if hrp then
        hrp.CFrame = cframe
    end
end


local function clickButton(btn)
    if not btn then return end

    local position = btn.AbsolutePosition
    local size = btn.AbsoluteSize
    local inset = GuiService:GetGuiInset()

    local centerX = position.X + size.X / 2
    local centerY = position.Y + size.Y / 2 + inset.Y

    VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, true, game, 0)
    task.wait(0.05)
    VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, false, game, 0)
end


local function WaitForRaidUI(timeout)
    local t = 0
    timeout = timeout or 10

    while t < timeout do
        local raid = player:FindFirstChild("PlayerGui")
            and player.PlayerGui:FindFirstChild("Main")
            and player.PlayerGui.Main:FindFirstChild("Func")
            and player.PlayerGui.Main.Func:FindFirstChild("Raid")

        if raid and raid.Visible == true then
            return raid
        end

        task.wait(0.05)
        t += 0.05
    end

    return nil
end


